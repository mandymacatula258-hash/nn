rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.token.email == "mandymacatula258@gmail.com";
    }

    function isLoggedIn() {
      return request.auth != null;
    }

    match /products/{id} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    match /orders/{id} {
      allow create:        if isLoggedIn();
      allow read, update:  if isAdmin();
    }

    match /reservations/{id} {
      allow create: if isLoggedIn();
      allow read:   if isLoggedIn() && (resource.data.uid == request.auth.uid || isAdmin());
      allow update: if isAdmin();
    }

  }
}
